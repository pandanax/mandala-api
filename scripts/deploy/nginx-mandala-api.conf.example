# Пример для Nginx в Docker на ВМ n8n: положить как отдельный файл в
# /opt/n8n/nginx/conf.d/ (том ./nginx/conf.d из compose), затем
# docker exec n8n-nginx nginx -t && docker exec n8n-nginx nginx -s reload
#
# 172.18.0.1 — шлюз Docker bridge к хосту (проверьте: docker inspect n8n-nginx … Gateway).
# Сертификат: certbot certonly … -d api.mandala-app.online (см. scripts/deploy/README.md).

server {
    listen 80;
    listen [::]:80;
    server_name api.mandala-app.online;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$server_name$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name api.mandala-app.online;

    ssl_certificate /etc/letsencrypt/live/api.mandala-app.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.mandala-app.online/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        proxy_pass http://172.18.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }
}
