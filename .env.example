# Скопируйте в `.env` и подставьте реальные значения. Секреты в репозиторий не коммитить.

# --- PostgreSQL (тикет 2: compose + приложение) ---
# Параметры ниже должны совпадать с URL в DATABASE_URL (user, password, db, порт).
POSTGRES_USER=mandala
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mandala
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mandala:changeme@localhost:5432/mandala

# --- Telegram-бот (тикет 9: long polling; тикет 10 — webhook в FastAPI) ---
TELEGRAM_BOT_TOKEN=000000000:placeholder-token-from-botfather
# Slug вертикали из ``agent_verticals`` (после seed: astrology, therapy)
TELEGRAM_VERTICAL_ID=astrology
# Секретный токен для webhook: передаётся в setWebhook как secret_token; в продакшене задавайте обязательно (см. README).
TELEGRAM_WEBHOOK_SECRET=your-secret-webhook-token

# --- HTTP сервер (тикет 10: FastAPI) ---
# Порт для FastAPI приложения (по умолчанию 8000)
PORT=8000
# Хост для привязки (по умолчанию 0.0.0.0)
HOST=0.0.0.0

# --- LLM, OpenAI-совместимый HTTP API (тикет 11+) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-placeholder-replace-me
LLM_MODEL=gpt-4o-mini
# Опционально: свой JSON с переопределениями per vertical_id (slug). Если не задан —
# подхватывается mandala/llm/vertical_overrides.json из пакета при наличии.
# LLM_VERTICAL_OVERRIDES_PATH=/absolute/path/to/overrides.json
# Эмбеддинги для RAG (тикет 16) — тот же LLM_BASE_URL / LLM_API_KEY:
# LLM_EMBEDDING_MODEL=text-embedding-3-small
# RAG_VECTOR_SIZE=1536

# --- Генерация изображений (тикет 15): OpenAI-compatible POST …/images/generations ---
# stub — только заглушка без HTTP и без фото в Telegram; openai_compatible — реальный вызов (URL в ответе).
# IMAGE_BASE_URL / IMAGE_API_KEY можно не задавать — возьмутся LLM_BASE_URL и LLM_API_KEY.
# IMAGE_GENERATION_PROVIDER=stub
# IMAGE_GENERATION_PROVIDER=openai_compatible
# IMAGE_BASE_URL=https://api.openai.com/v1
# IMAGE_API_KEY=sk-placeholder-replace-me
# IMAGE_MODEL=dall-e-3

# --- Анкета вертикали (тикет 13): шаги и промпты в JSON ---
# Опционально: свой JSON с цепочками per vertical_id. Если не задан —
# подхватывается mandala/verticals/intake_steps.json из пакета при наличии.
# MANDALA_INTAKE_STEPS_PATH=/absolute/path/to/intake_steps.json

# --- RAG / Qdrant (тикет 16, опционально) ---
# По умолчанию RAG выключен (none). Для индексации и retrieval: qdrant + URL (локально: podman compose up -d qdrant).
# MANDALA_RAG_BACKEND=none
# MANDALA_RAG_BACKEND=qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# MANDALA_QDRANT_COLLECTION=mandala_kb
# MANDALA_KB_ROOT=
# RAG_TOP_K=5
# RAG_MAX_CONTEXT_CHARS=8000
# RAG_CHUNK_CHARS=1200
# RAG_CHUNK_OVERLAP=200
# QDRANT_PORT=6333
