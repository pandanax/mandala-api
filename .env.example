# Скопируйте в `.env` и подставьте реальные значения. Секреты в репозиторий не коммитить.

# --- PostgreSQL (тикет 2: compose + приложение) ---
# Параметры ниже должны совпадать с URL в DATABASE_URL (user, password, db, порт).
POSTGRES_USER=mandala
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mandala
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mandala:changeme@localhost:5432/mandala

# --- Telegram-бот (тикет 9: long polling; тикет 10 — webhook в FastAPI) ---
TELEGRAM_BOT_TOKEN=000000000:placeholder-token-from-botfather
# Slug вертикали из ``agent_verticals`` (после seed: astrology, therapy)
TELEGRAM_VERTICAL_ID=astrology
# Секретный токен для webhook: передаётся в setWebhook как secret_token; в продакшене задавайте обязательно (см. README).
TELEGRAM_WEBHOOK_SECRET=your-secret-webhook-token

# --- HTTP сервер (тикет 10: FastAPI) ---
# Порт для FastAPI приложения (по умолчанию 8000)
PORT=8000
# Хост для привязки (по умолчанию 0.0.0.0)
HOST=0.0.0.0

# --- LLM, OpenAI-совместимый HTTP API (тикет 11+) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-placeholder-replace-me
LLM_MODEL=gpt-4o-mini
